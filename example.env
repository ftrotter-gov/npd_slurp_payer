# FHIR Dataset Downloader Configuration
# Copy this file to .env and customize for your environment

# Path to CSV file containing starting URLs
# This file should contain a "URL" column with index file URLs
# Rows with empty URLs will be skipped
# Space-separated URLs in a single cell will be parsed separately
STARTING_URLS_CSV=payer_url_list.csv

# Output directory for downloaded files
# Directory structure will mirror the URL paths
# Will be created automatically if it doesn't exist
OUTPUT_DIRECTORY=payer_raw_data_cache

# Download freshness threshold in days (whole integers only)
# Files younger than this will not be re-downloaded
# This allows the downloader to be resumable without unnecessary re-downloads
# Default: 1 day (24 hours)
DOWNLOAD_FRESHNESS_DAYS=1
